---
layout: layouts/base.njk
selectedMenuItem: Blog
---

<section id="blog">
    <h2>Blog Posts</h2>


    <ol>
        {% for post in collections.blog %}
            <li class="post" id="{{ post.data.title | slugify }}">
                <time datetime="{{ post.data.date.toISOString() }}">{{ post.data.date | readableDate }}</time>
                <a href="{{ post.url }}">
                    {{ post.data.title }}
                </a>
            </li>
        {% endfor %}
    </ol>
</section>